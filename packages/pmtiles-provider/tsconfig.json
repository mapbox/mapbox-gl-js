{
  "compilerOptions": {
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "WebWorker"],
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": [],
    "paths": {
      "mapbox-gl": ["../../src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
