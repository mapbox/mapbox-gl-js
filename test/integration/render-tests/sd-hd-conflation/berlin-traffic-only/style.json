        "showHDTraffic": true
      },
      "data": {
        "version": 8,
        "schema": {
          "sdCoverageFadeRange": {
            "default": [0, 0],
            "type": "number",
            "array": true
          },
          "sdCoverageSourceLayers": {
            "default": ["road", "structure"],
            "type": "string",
            "array": true
          },
          "showHDTraffic": {
            "default": false,
            "type": "boolean"
          }
        },
        "sources": {
          "hd-roads": {
            "tiles": [
              "local://tiles/hd/hd-road-{z}-{x}-{y}.mvt"
            ],
            "type": "vector"
          },
          "hd-traffic": {
            "tiles": [
