          },
          {
            "id": "road-motorway-trunk",
            "type": "line",
            "source": "composite",
            "source-layer": "road",
            "filter": [
              "all",
              ["match", ["get", "class"], ["motorway", "trunk"], true, false],
              ["match", ["get", "structure"], ["none", "ford"], true, false],
              ["case", ["<", ["zoom"], 14], true, ["!=", ["get", "hd_covered"], "true"]]
