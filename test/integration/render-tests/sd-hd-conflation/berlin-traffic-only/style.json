            "paint": {
              "fill-color": "hsl(220, 15%, 60%)"
            }
          },
          {
            "id": "hd-traffic",
            "type": "line",
            "source": "hd-traffic",
            "source-layer": "traffic",
            "minzoom": 14.4,
            "layout": {
              "line-cross-slope": 0,
              "line-cap": "round",
              "visibility": ["case", ["config", "showHDTraffic"], "visible", "none"]
            },
            "filter": [
              "all",
              [">=", ["get", "congestion_numeric"], 40],
              ["<=", ["get", "congestion_numeric"], 99],
              [
                "step", ["zoom"],
                ["match", ["get", "class"],
                  ["motorway", "motorway_link", "trunk", "trunk_link", "primary", "primary_link", "secondary", "secondary_link"],
                  true, false],
                13,
                ["match", ["get", "class"],
                  ["motorway", "motorway_link", "trunk", "trunk_link", "primary", "primary_link", "secondary", "secondary_link", "tertiary", "tertiary_link"],
                  true, false],
                15,
                ["match", ["get", "class"],
                  ["motorway", "motorway_link", "trunk", "trunk_link", "primary", "primary_link", "secondary", "tertiary", "tertiary_link", "secondary_link", "street", "street_limited", "service"],
                  true, false]
              ]
            ],
            "paint": {
              "line-width": [
                "interpolate", ["exponential", 1.5], ["zoom"],
                16, 5,
                17, 6,
                18, 8
              ],
              "line-dasharray": [3, 3],
              "line-translate": [0, 0],
              "line-color": [
                "step", ["get", "congestion_numeric"],
                "hsla(0, 0%, 0%, 0)",
                40, "#e77423",
                60, "#cc1100",
                80, "#80002a"
              ],
              "line-offset": [
                "interpolate", ["exponential", 1.5], ["zoom"],
                6, ["case", ["==", ["get", "source"], "sd"], 1.25, 0],
                16, ["case", ["==", ["get", "source"], "sd"],
                  ["match", ["get", "class"], ["motorway", "motorway_link", "trunk", "trunk_link"], 1, 2],
                  0],
                20, ["case", ["==", ["get", "source"], "sd"],
                  ["match", ["get", "class"], ["motorway", "motorway_link", "trunk", "trunk_link"], 10, 15],
                  0]
              ],
              "line-emissive-strength": 1,
              "line-occlusion-opacity": 0.5,
              "line-opacity": [
                "interpolate", ["linear"], ["zoom"],
                14.4, 0.2,
                14.9, 1,
                16.5, 1,
                17.5, 0.65
