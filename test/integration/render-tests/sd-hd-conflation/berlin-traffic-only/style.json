          },
          {
            "id": "hd-area",
            "type": "fill",
            "source": "hd-roads",
            "source-layer": "hd_road_polygon",
            "minzoom": 14,
            "layout": {
              "fill-elevation-reference": "hd-road-base",
              "fill-construct-bridge-guard-rail": true
