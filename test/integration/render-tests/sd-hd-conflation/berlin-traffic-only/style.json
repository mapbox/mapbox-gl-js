            "paint": {
              "line-width": [
                "interpolate", ["exponential", 1.5], ["zoom"],
                14, 3,
                18, 8
              ],
              "line-color": "hsl(200, 100%, 45%)"
            }
          },
          {
            "id": "road-street",
            "type": "line",
            "source": "composite",
            "source-layer": "road",
            "filter": [
              "all",
              ["match", ["get", "class"], ["street", "street_limited"], true, false],
              ["match", ["get", "structure"], ["none", "ford"], true, false],
              ["case", ["<", ["zoom"], 14], true, ["!=", ["get", "hd_covered"], "true"]]
