{
  "version": 8,
  "metadata": {
    "test": {
      "width": 64,
      "height": 64,
      "operations": [
        [
          "setFeatureState",
          {
            "source": "geojson",
            "id": "1"
          },
          {
            "hover": true
          }
        ],
        [
          "wait"
        ]
      ],
      "skip-test": [
        {"platform-tag-contains": "native", "reason": "skip - port https://github.com/mapbox/mapbox-gl-js/pull/6263 - needs issue"}
      ]
    }
  },
  "zoom": 2,
  "sources": {
    "geojson": {
      "type": "geojson",
      "data": {
            "type": "Feature",
            "id": 1,
            "properties": {
                "radius": 5
            },
            "geometry": {
                "type": "Point",
                "coordinates": [0,0]
            }
        }
    }
  },
  "layers": [
    {
      "id": "circle",
      "type": "circle",
      "source": "geojson",
      "paint": {
            "circle-radius": [ "get", "radius" ],
            "circle-opacity": 0.5,
            "circle-color": "#ff0000",
            "circle-stroke-width": [
                "case",
                ["boolean", ["feature-state", "hover"], false],
                4,
                1
            ]
        }
    }
  ]
}
