{
  "version": 8,
  "metadata": {
    "test": {
      "collisionDebug": true,
      "width": 512,
      "height": 512,
      "operations": [
        ["setProjection", "globe"],
        ["wait"]
      ],
      "skip-test": [
        {"platform-tag-contains": "native-linux", "reason": "Antialiasing"}
      ],
      "ignore-metrics": [
        {"platform-tag-contains": "native", "reason": "Flaky"},
        {"platform-tag-contains": "native-android", "reason": "Flaky"}
      ],
      "image-threshold": [
        {"platform-tag-contains": "", "threshold": 0.005}
      ]
    }
  },
  "center": [
    0,
    0
  ],
  "zoom": 1.2,
  "pitch": 0,
  "bearing": 90,
  "sources": {
    "geojson": {
      "type": "geojson",
      "data": "local://data/places.geojson"
    }
  },
  "fog": {},
  "glyphs": "local://glyphs/{fontstack}/{range}.pbf",
  "sprite": "local://sprites/sprite",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "white"
      }
    },
    {
      "id": "symbol",
      "type": "symbol",
      "source": "geojson",
      "layout": {
        "symbol-placement": "point",
        "text-field": "test test test",
        "text-font": [
          "Open Sans Semibold",
          "Arial Unicode MS Bold"
        ]
      }
    }
  ]
}
