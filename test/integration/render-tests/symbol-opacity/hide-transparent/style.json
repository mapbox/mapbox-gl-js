        {"platform-tag-contains": "native-linux", "reason": "skip - overdraw is not rendered in release mode https://mapbox.atlassian.net/browse/MAPSNAT-1116"},
        {"platform-tag-contains": "native-macos", "reason": "skip - overdraw is not rendered in release mode https://mapbox.atlassian.net/browse/MAPSNAT-1116"}
      ],
      "image-threshold": [
        {"platform-tag-contains": "", "threshold": 0.0002}
      ]
