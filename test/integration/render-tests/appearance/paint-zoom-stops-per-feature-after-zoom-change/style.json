{
  "_comment": "Verifies that pure-zoom step expressions update correctly after a zoom change. At initial zoom 2.5, only one icon grp=a (step 2.25) is visible. After setZoom(2.9): grp=b (step 2.75) must become visible because 2.9 exceeds its threshold; grp=c (step 2.95) must remain hidden because 2.9 < 2.95",
  "version": 8,
  "metadata": {"test": {"height": 64, "width": 128, "allowed": 0.001, "operations": [["wait"], ["setZoom", 2.9]]}},
  "center": [0, 0],
  "zoom": 2.5,
  "sprite": "local://sprites/sprite",
  "sources": {"geojson": {"type": "geojson", "data": {"type": "FeatureCollection", "features": [
    {"type": "Feature", "properties": {"grp": "a"}, "geometry": {"type": "Point", "coordinates": [-3, 0]}},
    {"type": "Feature", "properties": {"grp": "b"}, "geometry": {"type": "Point", "coordinates": [0, 0]}},
    {"type": "Feature", "properties": {"grp": "c"}, "geometry": {"type": "Point", "coordinates": [3, 0]}}
  ]}}},
  "layers": [
    {"id": "background", "type": "background", "paint": {"background-color": "white"}},
    {"id": "icon", "type": "symbol", "source": "geojson",
     "layout": {"icon-image": "building-12"},
     "paint": {"icon-opacity": 1},
     "appearances": [
       {"name": "a", "condition": ["==", ["get", "grp"], "a"], "properties": {"icon-opacity": ["step", ["zoom"], 0, 2.25, 1]}},
       {"name": "b", "condition": ["==", ["get", "grp"], "b"], "properties": {"icon-opacity": ["step", ["zoom"], 0, 2.75, 1]}},
       {"name": "c", "condition": ["==", ["get", "grp"], "c"], "properties": {"icon-opacity": ["step", ["zoom"], 0, 2.95, 1]}}
     ]}
  ]
}
