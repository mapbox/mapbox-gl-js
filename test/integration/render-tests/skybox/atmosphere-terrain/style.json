{
  "version": 8,
  "metadata": {
    "test": {
      "height": 256,
      "width": 512,
      "operations": [
        ["wait"]
      ],
      "skip-test": [
        {"platform-tag-contains": "web-windows-chrome", "reason": "Timing out on CI. Tracked in https://github.com/mapbox/mapbox-gl-js/issues/12407"},
        {"platform-tag-contains": "native-ios", "reason": "skip due to CI timeout: https://mapbox.atlassian.net/browse/MAPSNAT-2137"},
        {"platform-tag-contains": "native-macos", "reason": "skip due to CI timeout: https://mapbox.atlassian.net/browse/MAPSNAT-2137"}
      ],
      "ignore-metrics": [
        {"platform-tag-contains": "native", "reason": "Flaky network metrics"},
        {"platform-tag-contains": "native-ios-metal", "reason": "Flaky"},
        {"platform-tag-contains": "native-android", "reason": "Flaky"}
      ]
    }
  },
  "center": [-113.27903, 35.98],
  "zoom": 13.5,
  "pitch": 85,
  "terrain": {
    "source": "rgbterrain"
  },
  "sources": {
    "rgbterrain": {
      "type": "raster-dem",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.terrain.png"
      ],
      "maxzoom": 15,
      "tileSize": 256
    },
    "satellite": {
      "type": "raster",
      "tiles": [
        "local://tiles/{z}-{x}-{y}.satellite.png"
      ],
      "maxzoom": 17,
      "tileSize": 256
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "red"
      }
    },
    {
      "id": "raster",
      "type": "raster",
      "source": "satellite",
      "paint": {
        "raster-fade-duration": 0
      }
    },
    {
      "id": "sky",
      "type": "sky",
      "paint": {
        "sky-type": "atmosphere",
        "sky-atmosphere-sun": [0, 0],
        "sky-atmosphere-sun-intensity": 30
      }
    }
  ]
}
