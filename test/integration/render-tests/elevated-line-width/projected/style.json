{
  "version": 8,
  "metadata": {
    "test": {
      "height": 256,
      "width": 256,
      "operations": [
        ["setProjection", "albers"],
        ["wait"]
      ],
      "skip-test": [
        {"platform-tag-contains": "web", "reason": "line-width projected"},
        {"platform-tag-contains": "native", "reason": "skip - Known issues https://mapbox.atlassian.net/browse/MAPS3D-1494"}
      ]
    }
  },
  "zoom": 6,
  "sources": {
    "graticule": {
      "type": "geojson",
      "data": "local://data/dense-graticule.geojson"
    }
  },
  "layers": [
    {
      "id": "graticule",
      "source": "graticule",
      "type": "line",
      "layout": {
        "line-z-offset": 0.01
      },
      "paint": {
          "line-width": 1,
          "line-color": "#aaa"
      }
    }
  ]
}