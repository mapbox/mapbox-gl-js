{
  "version": 8,
  "metadata": {
    "test": {
      "width": 512,
      "height": 512,
      "operations": [
        [
          "addCustomSource",
          "custom-source",
          "local://tiles/mapbox.satellite/{z}-{x}-{y}.png"
        ],
        [
          "addLayer",
          {
            "id": "custom-source",
            "type": "raster",
            "source": "custom-source",
            "paint": {
              "raster-fade-duration": 0
            }
          }
        ],
        ["wait"],
        ["setProjection", "equalEarth"],
        ["wait"]
      ],
      "skip-test": [
        {"platform-tag-contains": "native", "reason": "not implemented in gl-native yet"}
      ],
      "image-threshold": [
        {"platform-tag-contains": "", "threshold": 0.005}
      ]
    }
  },
  "sources": {},
  "layers": []
}
