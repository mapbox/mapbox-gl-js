{
  "version": 8,
  "metadata": {
    "test": {
      "width": 256,
      "height": 256,
      "operations": [
        ["setProjection", "albers"],
        ["wait"]
      ],
      "description": "Contains two expected images (for ubyte-based rendering and half-float-based); one of them should pass depending on platform.",
      "skip-test": [
        {"platform-tag-contains": "native", "reason": "skip - https://github.com/mapbox/mapbox-gl-native-internal/issues/2534"}
      ]
    }
  },
  "center": [
    0,
    0
  ],
  "zoom": 3,
  "sources": {
    "geojson": {
      "type": "geojson",
      "data": {
        "type": "Point",
        "coordinates": [
          0,
          0
        ]
      }
    },
    "graticule": {
      "type": "geojson",
      "data": "local://data/graticule.geojson"
    }
  },
  "layers": [
    {
      "id": "heatmap",
      "type": "heatmap",
      "source": "geojson",
      "paint": {
        "heatmap-radius": 50
      }
    },
    {
      "id": "graticule",
      "source": "graticule",
      "type": "line",
      "paint": {
          "line-width": 1,
          "line-color": "#aaa"
      }
    }
  ]
}
