{
    "version": 8,
    "metadata": {
        "skipLayerDelete": true,
        "test": {
            "width": 256,
            "height": 256,
            "operations": [
                [
                  "wait"
                ],
                [
                  "setFeatureState",
                  { "source": "mapbox", "id": 1},
                  { "big": true }
                ],
                [
                  "wait"
                ]
              ],
            "queryGeometry": [
                160,
                120
            ],
            "skip-test": [
                {"platform-tag-contains": "native", "reason": "Port https://github.com/mapbox/mapbox-gl-js/pull/9198"}
            ]
        }
    },
    "projection": {
        "name": "globe"
    },
    "center": [ -20, 0 ],
    "sources": {
        "mapbox": {
            "type": "geojson",
            "data": {
                "type": "FeatureCollection",
                "features": [
                    {
                        "id": 1,
                        "type": "Feature",
                        "geometry": {
                            "type": "LineString",
                            "coordinates": [
                                [ 0, 0],
                                [ 5, 15]
                            ]
                        }
                    }
                ]
            }
        }
    },
    "layers": [
        {
            "id": "line",
            "type": "line",
            "source": "mapbox",
            "paint": {
                "line-width": ["case",
                        ["boolean", ["feature-state", "big"], false],
                        ["number", 20],
                        ["number", 1]
                    ]
            }
        }
    ]
}
